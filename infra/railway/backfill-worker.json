{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "services/backfill-worker/Dockerfile",
    "watchPatterns": [
      "contracts/**",
      "config/**",
      "engine/**",
      "services/persistence/**",
      "services/backfill-worker/**",
      "scripts/backfill_runner.py",
      "scripts/backfill_bars_ibkr.py",
      "scripts/backfill_signals.py",
      "pyproject.toml",
      "uv.lock"
    ]
  },
  "deploy": {
    "startCommand": "python -m scripts.backfill_runner",
    "restartPolicyType": "NEVER"
  }
}
