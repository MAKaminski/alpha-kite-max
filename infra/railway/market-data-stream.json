{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "services/market-data-stream/Dockerfile",
    "watchPatterns": [
      "contracts/**",
      "config/**",
      "engine/data_feeds/**",
      "services/market_data_stream/**",
      "services/market-data-stream/**",
      "services/persistence/**",
      "pyproject.toml"
    ]
  },
  "deploy": {
    "startCommand": "python -m services.market_data_stream",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 30
  }
}
