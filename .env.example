# alpha-kite-v2 environment variables.
# Copy to .env. Never commit secrets.

# ──────────── Supabase ────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Local docker-compose builds the URL from POSTGRES_USER/PASSWORD/DB below.
SUPABASE_DB_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:54322/postgres

# ──────────── Local Postgres (docker-compose only) ───────────────────────
# Used by docker-compose.yml's supabase-db service. NEVER reuse for prod.
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=postgres

# ──────────── IBKR (paper account only in v1) ────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=17
IBKR_USERNAME=paper-username
IBKR_PASSWORD=paper-password
IBKR_TRADING_MODE=paper

# ──────────── Optional data feed providers ───────────────────────────────
# YFinance is keyless. Tiingo / Polygon are optional alternatives for Phase 2.
TIINGO_API_KEY=
POLYGON_API_KEY=

# ──────────── Engine runtime ─────────────────────────────────────────────
STRATEGY_CONFIG=./config/strategy.yaml
LOG_LEVEL=INFO

# ──────────── Frontend (Vercel) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
